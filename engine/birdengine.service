[Unit]
Description=BirdEngine — Bird detection engine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=BIRDASH_USER
WorkingDirectory=BIRDASH_HOME/birdash/engine
ExecStart=BIRDASH_HOME/birdash/engine/venv/bin/python BIRDASH_HOME/birdash/engine/engine.py
Restart=on-failure
RestartSec=10
TimeoutStopSec=60
UMask=0022
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
